API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=true

# Comma-separated origins for the new Next.js frontend during development, e.g. http://localhost:3000
CORS_ALLOW_ORIGINS=http://localhost:3000

# Shared SQLite DB path – must match settings.json -> local_db_path resolution
DATABASE_PATH=%USERPROFILE%\.eurbanizam\db\eurbanizam_local.sqlite

# Optional: override finance PIN (otherwise taken from settings.json)
# EURBANIZAM_FINANCE_PIN=1234

