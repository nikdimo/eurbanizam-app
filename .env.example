API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=false

# Comma-separated origins served through the frontend.
CORS_ALLOW_ORIGINS=http://127.0.0.1:3000

# Build-time API target used by Next.js rewrites.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Runtime data path on VPS.
DATABASE_PATH=/home/nikola/.eurbanizam/db/eurbanizam_local.sqlite

# Optional override for finance PIN.
# EURBANIZAM_FINANCE_PIN=
